# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: your numeric Telegram user ID. If left empty, the first person
# to send /start to the bot claims ownership and everyone else is locked out.
TELEGRAM_OWNER_ID=

# --- Claude API ---
ANTHROPIC_API_KEY=
# Model used for all agents (per the build guide: Sonnet 4.6)
AGENT_MODEL=claude-sonnet-4-6

# --- Publishing (Postiz) ---
# API key from the Postiz dashboard (Settings -> Public API). With only the
# key set, the cloud API (https://api.postiz.com/public/v1) is used.
# Self-hosted instances set the URL explicitly: https://your-postiz/api/public/v1
# Only the API host needs outbound network access. Safe to set during the
# dry-run week: while DRY_RUN=true the publish step logs instead of posting.
POSTIZ_API_URL=
POSTIZ_API_KEY=

# Global safety switch. When true (the default), the full pipeline runs but the
# publish step logs instead of posting. Do NOT set to false until the dry-run
# week is explicitly complete.
DRY_RUN=true

# --- Storage ---
DB_PATH=./data/launch.db

# --- Timezone for schedulers (daily/weekly runs) ---
TZ=America/Denver

# .env configures LOCAL/VPS runs (src/index.js) and, via .dev.vars, wrangler
# dev. Production on Cloudflare Workers uses `wrangler secret put` and the
# [vars] block in wrangler.toml instead.

# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: your numeric Telegram user ID. If left empty, the first person
# to send /start to the bot claims ownership and everyone else is locked out.
TELEGRAM_OWNER_ID=

# --- Claude API ---
ANTHROPIC_API_KEY=
# Model used for all agents (per the build guide: Sonnet 4.6)
AGENT_MODEL=claude-sonnet-4-6

# --- Publishing (Postiz) ---
# Leave empty until the dry-run week is complete.
# POSTIZ_API_URL is the full public API base:
#   self-hosted: https://your-postiz-host/api/public/v1
#   cloud:       https://api.postiz.com/public/v1
# After configuring, run /channels in Telegram to map linkedin/instagram/x.
POSTIZ_API_URL=
POSTIZ_API_KEY=

# Global safety switch. When true (the default), the full pipeline runs but the
# publish step logs instead of posting. Do NOT set to false until the dry-run
# week is explicitly complete.
DRY_RUN=true

# --- Storage ---
DB_PATH=./data/launch.db

# --- Timezone for schedulers (daily/weekly runs) ---
TZ=America/Denver

# --- Schedulers ---
# Set to false to run the bot without the daily/weekly cron jobs (dev bots).
ENABLE_SCHEDULERS=true

# --- Self-hosted Postiz (docker compose --profile postiz) ---
# Public URL of the Postiz UI. Social OAuth needs HTTPS on a real domain
# (Caddy or a Cloudflare Tunnel in front of port 5000).
POSTIZ_MAIN_URL=
# Any long random string, e.g. from: openssl rand -hex 32
POSTIZ_JWT_SECRET=
POSTIZ_DB_PASSWORD=
# Set true after you create your Postiz account so no one else can register.
POSTIZ_DISABLE_REGISTRATION=false
